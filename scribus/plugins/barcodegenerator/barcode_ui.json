{
    "_comment": [
        "UI configuration for the Scribus barcode generator plugin.",
        "Augments data provided by the BWIPP C library. If this file is absent,",
        "the plugin works but with no combo boxes populated or checkboxes enabled.",
        "",
        "families.<name>:",
        "  Keys must match the FMLY metadata names from barcode.ps exactly.",
        "  order   - Sort position in the family combo box (default: 0)",
        "  enabled - Show/hide this family (default: true)",
        "  desc    - Override the display name",
        "",
        "encoders.<name>:",
        "  Keys must match the encoder resource names from barcode.ps exactly.",
        "  Only include properties that differ from defaults.",
        "  order   - Sort position within its family (default: 0)",
        "  enabled - Show/hide this encoder (default: true)",
        "  desc    - Override the description from the library",
        "  exam    - Override the example data input",
        "  exop    - Override the example options string",
        "  combo1  - First combo box:  { name, key, values: [...] }",
        "  combo2  - Second combo box: { name, key, values: [...] }",
        "            name   = UI label, key = options string key,",
        "            values = list of selectable values",
        "  includetext, guardwhitespace, includecheck,",
        "  includecheckintext, parse, parsefnc:",
        "            true = checkbox enabled for this encoder (default: false)",
        "  dotty      - true = dotty checkbox enabled (default: false)",
        "  dottyForced - true = dotty always on and locked (default: false)",
        "  height     - true = bar height slider enabled (default: false)",
        "  bearer     - true = bearer bar option available (default: false)",
        "  fixedtext  - true = encoder places text per-character; text",
        "               align/offset/direction/gaps disabled unless alttext set"
    ],
    "families": {
        "Point Of Sale": {
            "order": 1
        },
        "Supply Chain": {
